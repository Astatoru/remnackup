# Ugly date
DATE=$(date +%Y_%m_%d_%H_%M_%S%Z)
# Pretty date
DATE2=$(date +%Y-%m-%d@%H:%M:%S%Z)
# Script dependencies
declare -a DEPENDENCIES="(docker tar gzip)"
# Toggle root support
declare ROOT="${ROOT:-OFF}"
# Toggle backup everything
declare ALL="${ALL:-OFF}"

# Toggle database backup
declare BACKUPDB="${BACKUPDB:-OFF}"
# Database username
declare DBUSER="${DBUSER:-postgres}"
# Path where database will be dumped
declare DUMPPATH="${DUMPPATH:-$PWD}"
# Dump name
declare DUMPNAME="${DUMPNAME:-database-$DATE.dump}"
# Path to archive
declare ARCHIVEPATH="${ARCHIVEPATH:-$PWD}"
# Name of archive
declare ARCHIVENAME="${ARCHIVENAME:-database-$DATE.tar.gz}"
# Databse container name
declare CONTAINER="remnawave-db"

# Toggle panel config backup
declare BACKUPCONFIG="${BACKUPCONFIG:-OFF}"
# Path where to look for panel config
declare CONFIGPATH="${CONFIGPATH:-/opt/remnawave}"
# Path to archive with config backup
declare ARCHIVEPATH2="${ARCHIVEPATH2:-$PWD}"
# Archive name with config
declare ARCHIVENAME2="${ARCHIVENAME2:-config-$DATE.tar.gz}"

# Toggle github support
declare GITHUB="${GITHUB:-OFF}"
# Path to github repository
declare REPOSITORY

# Display error messages
error() {
  local MESSAGE="$1"
  # Check whether stderr is in interactive mode
  if [[ -t 2 ]]; then
    >&2 printf "%b\n" "\033[01;31mERROR\033[0m: $MESSAGE"
  else
    >&2 printf "%s\n" "ERROR: $MESSAGE"
  fi
}

# Display info messages
info() {
  local MESSAGE="$1"
  # Check whether stdout is in interactive mode
  if [[ -t 1 ]]; then
    printf "%b\n" "\033[01;34mINFO\033[0m: $MESSAGE"
  else
    printf "%s\n" "INFO: $MESSAGE"
  fi
}

checkRoot() {
  if [[ "${ROOT^^}" = "OFF" ]]; then
    if ((EUID == 0)); then
      error "Running the script as root is discouraged, but you can disable this check using \"\$ROOT\" variable"
      exit 1
    fi
  fi
}

checkDependencies() {
  for CMD in "${DEPENDENCIES[@]}"; do
    if ! command -v "$CMD" &>/dev/null; then
      error "$CMD is not installed"
      exit 1
    elif [[ "$CMD" = "docker" ]]; then
      if ! docker ps &>/dev/null; then
        error "Your current user cannot run docker without root priveleges"
        exit 1
      fi
    fi
  done
}

checkEnableAll() {
  if [[ "${ALL^^}" = "ON" ]]; then
    BACKUPDB="ON"
    GITHUB="ON"
    BACKUPCONFIG="ON"
  fi
}

# Remove temporary files
removeTemporary() {
  rm -f "$DUMPPATH/$DUMPNAME"
  rm -f "$ARCHIVEPATH/$ARCHIVENAME"
  rm -f "$ARCHIVEPATH2/$ARCHIVENAME2"
}

success() {
  if [[ "${BACKUPDB^^}" == "ON" || "${BACKUPCONFIG^^}" == "ON" ]]; then
    info "Remnawave backup successfully made at $DATE2"
  else
    info "Seems like you haven't selected anything for backup"
  fi
}

backupDatabase() {
  local CONTAINERUP=$(2>/dev/null docker inspect --format "{{.Name}}" "$CONTAINER")
  if [[ "${BACKUPDB^^}" = "ON" ]]; then
    # Check whether path to database dump is writeable
    # And is a directory
    if [[ ! -w "$DUMPPATH" && ! -d "$DUMPPATH" ]]; then
      error "$DUMPPATH is either not writable or not a directory"
      exit 1
    # Check whether path to archive is writeable
    # And is a directory
    elif [[ ! -w "$ARCHIVEPATH" && ! -d "$ARCHIVEPATH" ]]; then
      error "$ARCHIVEPATH is either not writable or not a directory"
      exit 1
    # Check whether container with database is up
    elif [[ ! "${CONTAINERUP#*/}" == "$CONTAINER" ]]; then
      error "Container \"$CONTAINER\" doesn't exists"
      exit 1
    fi
    # Dump database
    docker exec --tty "$CONTAINER" pg_dumpall --clean --username="$DBUSER" >"$DUMPPATH/$DUMPNAME"
    # Compress dump to .tar.gz archive
    tar --create --gzip --file="$ARCHIVEPATH/$ARCHIVENAME" --directory "$DUMPPATH" "$DUMPNAME"
    # Remove dump
    rm -f "$DUMPPATH/$DUMPNAME"
    info "Archive: \"$ARCHIVENAME\" created successfully"
  fi
}

backupConfig() {
  if [[ "${BACKUPCONFIG^^}" = "ON" ]]; then
    if [[ ! -d "$CONFIGPATH" && ! -e "$CONFIGPATH" ]]; then
      error "$CONFIGPATH is either doesn't exist or not a directory"
      exit 1
    elif [[ ! -d "$ARCHIVEPATH2" && ! -e "$ARCHIVEPATH2" ]]; then
      error "$ARCHIVEPATH2 is either doesn't exist or not a directory"
      exit 1
    fi
    tar --create --gzip --file="$ARCHIVEPATH2/$ARCHIVENAME2" "$CONFIGPATH" 2>/dev/null
    info "Archive: \"$ARCHIVENAME2\" created successfully"
  fi
}

uploadToGithub() {
  if [[ "${BACKUPDB^^}" == "ON" || "${BACKUPCONFIG^^}" == "ON" ]]; then
    if [[ "${GITHUB^^}" = "ON" ]]; then
      # Check whether user specified repository
      if [[ -z "$REPOSITORY" ]]; then
        error "Provide full path to your repository"
        exit 1
      # Check whether repository is writeable
      # And is a directory
      elif [[ ! -w "$REPOSITORY" && ! -d "$REPOSITORY" ]]; then
        error "$REPOSITORY is either not writable or not a directory"
        exit 1
      fi
      # Push changes to github
      # If database backup is enabled
      # Move archive with database to repository
      if [[ "$BACKUPDB" == "ON" ]]; then
        mv "$ARCHIVENAME" "$REPOSITORY"
      fi
      # If config backup is enabled
      # Move archive with config to repository
      if [[ "$BACKUPCONFIG" = "ON" ]]; then
        mv "$ARCHIVENAME2" "$REPOSITORY"
      fi
      # Remove temporary files
      removeTemporary
      # Go to repository
      cd "$REPOSITORY"
      # Pull changes from remote repository before staging
      git pull
      # Stage, create commit and push changes to remote repository
      git add .
      git commit --message "$HOSTNAME backup: $DATE2"
      git push
      info "Backup uploaded to github"
    fi
  fi
}

# Main function
main() {
  set -o "errexit"
  trap "error 'Something went wrong. Removing temporary files...'; removeTemporary && exit 1" EXIT
  checkRoot
  checkDependencies
  checkEnableAll
  backupDatabase
  backupConfig
  uploadToGithub
  success
  trap "" EXIT
}

# Execute main function
main "$@"
